{
  "name": "vcp-mobile",
  "private": true,
  "version": "1.0.7",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "qa:regression": "bash qa/regression.sh",
    "qa:robustness": "bash qa/robustness.sh",
    "tauri": "tauri",
    "io:write": "node scripts/nova_utils.cjs write",
    "io:append": "node scripts/nova_utils.cjs append",
    "memory:refresh": "node scripts/refresh_manifest.cjs",
    "check": "vue-tsc --noEmit && cd src-tauri && cargo check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run src/tests/unit",
    "test:integration": "vitest run src/tests/integration",
    "test:coverage": "vitest run --coverage",
    "e2e:android:env": "node tests/e2e-android/scripts/adb-env.cjs",
    "e2e:android:grant": "node tests/e2e-android/scripts/grant-permissions.cjs",
    "e2e:android:smoke": "node tests/e2e-android/scripts/adb-smoke.cjs",
    "perf:apk-size": "node tests/perf/scripts/measure_apk_size.cjs",
    "perf:startup": "node tests/perf/scripts/measure_startup_adb.cjs",
    "perf:collect": "node tests/perf/scripts/collect_android_dumpsys.cjs",
    "perf:rust-bench": "node tests/perf/scripts/run_rust_bench.cjs",
    "dev:android": "node scripts/tauri_android_dev.cjs",
    "dev:usb": "node scripts/tauri_android_dev.cjs --usb"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@vueuse/core": "^14.2.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.2",
    "katex": "^0.16.45",
    "lucide-vue-next": "^0.576.0",
    "marked": "^18.0.4",
    "mermaid": "^11.14.0",
    "morphdom": "^2.7.8",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "sortablejs": "^1.15.7",
    "tauri-plugin-vcp-mobile": "file:src-tauri/plugins/vcp-mobile",
    "vue": "^3.5.33",
    "vue-cropper": "^1.1.4",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/ph": "^1.2.2",
    "@pinia/testing": "^1.0.3",
    "@tauri-apps/cli": "2.11.2",
    "@types/katex": "^0.16.8",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@unocss/preset-attributify": "^66.6.8",
    "@unocss/preset-typography": "^66.6.8",
    "@unocss/preset-uno": "^66.6.8",
    "@unocss/reset": "^66.6.8",
    "@unocss/transformer-directives": "^66.6.8",
    "@unocss/transformer-variant-group": "^66.6.8",
    "@unocss/vite": "^66.6.8",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.3",
    "typescript": "~5.6.3",
    "unocss": "^66.6.8",
    "vite": "^6.4.2",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.2.12"
  }
}
