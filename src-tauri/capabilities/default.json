{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "vcp-portal-*"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-close"
  ],
  "protocols": {
    "vcp-avatar": {
      "name": "vcp-avatar",
      "scopes": ["**"]
    },
    "vcp": {
      "name": "vcp",
      "scopes": ["**"]
    },
    "vcp-portal": {
      "name": "vcp-portal",
      "scopes": ["**"]
    }
  }
}